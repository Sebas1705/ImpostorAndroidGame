@startuml
title Diagrama de clases - ejemplo de modelos/domain

class User {
  - id: String
  - name: String
  - email: String
  + isValid(): Boolean
}

class UserDTO {
  - id: String
  - fullName: String
  - emailAddress: String
}

class UserMapper {
  + toDomain(dto: UserDTO): User
  + toDto(user: User): UserDTO
}

UserMapper ..> UserDTO
UserMapper ..> User

@enduml
