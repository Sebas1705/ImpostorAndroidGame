rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Salas públicas: cualquiera puede leer, solo usuarios autenticados pueden crear/borrar.
    match /game_rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete, update: if request.auth != null;
    }

    // Contador de sesiones de internet: solo lectura/escritura autenticada.
    match /config/internet_usage {
      allow read, write: if request.auth != null;
    }

    // Tokens de sesión única: cada usuario solo puede leer/escribir su propio documento.
    // Cuando un dispositivo escribe un nuevo token, los demás lo detectan y cierran sesión.
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
